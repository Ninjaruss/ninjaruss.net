{
	"version": 3,
	"routes": [
		{
			"src": "^/media$",
			"headers": {
				"Location": "/shelf"
			},
			"status": 301
		},
		{
			"src": "^/media(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?$",
			"headers": {
				"Location": "/shelf/$1"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/live-status/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/twitch-live/?$",
			"dest": "_render"
		}
	]
}