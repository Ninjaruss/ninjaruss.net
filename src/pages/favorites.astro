---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavPill from '../components/NavPill.astro';
import EmblemCard from '../components/EmblemCard.astro';

const allFavorites = await getCollection('media', ({ data }) => !data.draft && data.isFavorite);
const sortedFavorites = allFavorites.sort((a, b) =>
  new Date(b.data.publishedAt || 0).getTime() - new Date(a.data.publishedAt || 0).getTime()
);

// Extract unique types for filtering
const allTypes = [...new Set(allFavorites.map(f => f.data.content_type))].sort();
const totalCount = sortedFavorites.length;
---

<BaseLayout title="Favorites" description="Curated highlights and inspirations">
  <NavPill />

  <div class="favorites-container">
    <header class="favorites-header p3r-animate">
      <div class="favorites-header__left">
        <span class="favorites-header__section">Collection</span>
      </div>
      <div class="favorites-header__center">
        <h1 class="favorites-title">Favorites</h1>
      </div>
      <div class="favorites-header__right">
        <span class="favorites-header__count" id="favorites-count">{totalCount}</span>
        <span class="favorites-header__count-label">entries</span>
      </div>
    </header>

    <div class="favorites-filter p3r-animate" style="--stagger-delay: 50ms;">
      <button class="type-pill" data-type="all" aria-pressed="false">all</button>
      {allTypes.map(type => (
        <button class="type-pill" data-type={type} aria-pressed="false">
          {type}
        </button>
      ))}
    </div>

    <div class="favorites-grid">
      {sortedFavorites.length > 0 ? (
        sortedFavorites.map((entry, index) => (
          <a
            href={`/favorites/${entry.slug}`}
            class="favorite-card p3r-animate"
            data-type={entry.data.content_type}
            style={`--stagger-delay: ${(index % 20) * 50}ms`}
          >
            <div class="favorite-card__emblem">
              <EmblemCard emblemSrc={entry.data.emblem} isInitiallyFlipped={true} disableLightbox={true} />
            </div>
            <div class="favorite-card__content">
              <h3 class="favorite-card__title">{entry.data.title}</h3>
              <span class="favorite-card__type">{entry.data.content_type}</span>
            </div>
          </a>
        ))
      ) : (
        <p class="empty-state">No favorites yet.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .favorites-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  /* Editorial three-part header */
  .favorites-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: flex-end;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: var(--border-thick) solid var(--color-gold);
  }

  .favorites-header__left {
    display: flex;
    align-items: flex-end;
  }

  .favorites-header__right {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    gap: var(--space-xs);
  }

  .favorites-header__section {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding-bottom: 4px; /* Optical alignment with title baseline */
  }

  .favorites-header__center {
    text-align: center;
  }

  .favorites-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--color-gold);
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0;
  }

  .favorites-header__count {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-gold);
    line-height: 1;
  }

  .favorites-header__count-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 6px; /* Align with count bottom */
  }

  /* Filter Pills — mono ghost style */
  .favorites-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: flex-start;
    margin-bottom: var(--space-2xl);
    padding: var(--space-sm) 0;
    border-bottom: var(--border-hairline) solid var(--color-border);
  }

  .type-pill {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: lowercase;
    letter-spacing: 0.03em;
    padding: var(--space-xs) var(--space-md);
    background: transparent;
    color: var(--color-text-subtle);
    border: var(--border-hairline) solid var(--color-border);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .type-pill:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background: var(--color-bg-elevated);
  }

  .type-pill.is-selected {
    background: var(--color-gold);
    color: var(--color-black);
    border-color: var(--color-gold);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    box-shadow: 0 0 12px rgba(255, 229, 44, 0.3);
  }

  .type-pill:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* Grid Layout */
  .favorites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-xl);
    padding: var(--space-2xl) 0;
  }

  @media (max-width: 768px) {
    .favorites-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .favorites-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .favorites-container {
      padding: var(--space-xl) var(--space-sm);
    }

    .favorites-header {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      text-align: center;
    }

    .favorites-header__left,
    .favorites-header__right {
      justify-content: center;
    }
  }

  /* Favorite Card */
  .favorite-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-decoration: none;
    transition: transform var(--transition-base);
    contain: layout style paint;
  }

  .favorite-card:hover {
    transform: translateY(-4px);
  }

  .favorite-card:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .favorite-card__emblem {
    width: 100%;
    max-width: 240px;
    margin: 0 auto;
  }

  /* Content always visible at reduced opacity — hover sharpens */
  .favorite-card__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: 0 var(--space-sm);
    opacity: 0.55;
    transition: opacity var(--transition-base);
  }

  .favorite-card:hover .favorite-card__content {
    opacity: 1;
  }

  .favorite-card__title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    color: var(--color-text);
    text-align: center;
    line-height: 1.3;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  /* Type badge hidden at rest, revealed on hover */
  .favorite-card__type {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-gold-dim);
    opacity: 0;
    transition: opacity var(--transition-base) 100ms;
  }

  .favorite-card:hover .favorite-card__type {
    opacity: 1;
  }

  .favorite-card.is-hidden {
    display: none;
  }

  /* Empty State */
  .empty-state {
    grid-column: 1 / -1;
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    padding: var(--space-2xl);
  }

  @media (prefers-reduced-motion: reduce) {
    .favorite-card__content,
    .favorite-card__type {
      transition: none;
    }
  }
</style>

<script>
  function initFavoritesFilter() {
    const pills = document.querySelectorAll('.type-pill');
    const cards = document.querySelectorAll('.favorite-card');
    const countEl = document.getElementById('favorites-count');

    // Get filter type from URL
    function getTypeFromURL(): string {
      const params = new URLSearchParams(window.location.search);
      return params.get('type') || 'all';
    }

    // Update URL with current filter
    function updateURL(type: string) {
      const params = new URLSearchParams(window.location.search);

      if (type === 'all') {
        params.delete('type');
      } else {
        params.set('type', type);
      }

      const newURL = `${window.location.pathname}${params.toString() ? '?' + params.toString() : ''}`;
      history.replaceState({ type }, '', newURL);
    }

    // Apply filter for a given type
    function applyFilter(selectedType: string) {
      // Update pill states
      pills.forEach(p => {
        const pillType = p.getAttribute('data-type');
        const isSelected = pillType === selectedType;
        p.classList.toggle('is-selected', isSelected);
        p.setAttribute('aria-pressed', String(isSelected));
      });

      // Filter cards with stagger animation
      let visibleCount = 0;
      cards.forEach((card) => {
        const cardType = card.getAttribute('data-type');
        const isVisible = selectedType === 'all' || cardType === selectedType;

        if (isVisible) {
          card.classList.remove('is-hidden');
          // Reset and reapply animation with stagger
          (card as HTMLElement).style.animation = 'none';
          setTimeout(() => {
            (card as HTMLElement).style.animation = '';
            (card as HTMLElement).style.setProperty('--stagger-delay', `${visibleCount * 50}ms`);
            visibleCount++;
          }, 10);
        } else {
          card.classList.add('is-hidden');
          visibleCount; // don't increment for hidden cards
        }
      });

      // Update visible count in header
      if (countEl) {
        const visible = selectedType === 'all'
          ? cards.length
          : [...cards].filter(c => c.getAttribute('data-type') === selectedType).length;
        countEl.textContent = String(visible);
      }
    }

    // Initialize from URL on page load
    const initialType = getTypeFromURL();
    applyFilter(initialType);

    // Handle pill clicks
    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const selectedType = pill.getAttribute('data-type');
        if (!selectedType) return;

        applyFilter(selectedType);
        updateURL(selectedType);
      });
    });

    // Handle browser back/forward
    window.addEventListener('popstate', (e: PopStateEvent) => {
      const type = (e.state as { type?: string })?.type || getTypeFromURL();
      applyFilter(type);
    });
  }

  // Initialize on page load
  document.addEventListener('astro:page-load', () => {
    initFavoritesFilter();
  });

  // Also initialize on DOMContentLoaded for non-Astro navigation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initFavoritesFilter();
    });
  } else {
    initFavoritesFilter();
  }
</script>
