---
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavPill from '../components/NavPill.astro';
import ObjectivesBillboard from '../components/ObjectivesBillboard.astro';
import { parseObjectives } from '../utils/objectives';

// Get the latest now entry from the collection
const allNowPosts = await getCollection('now', ({ data }) => !data.draft);
const sortedPosts = allNowPosts.sort((a, b) =>
  b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
const latestPost = sortedPosts[0];

// Render the markdown content
const { Content } = await latestPost.render();

// Format date in UTC for consistency
const lastUpdated = latestPost.data.publishedAt.toLocaleDateString('en-US', {
  timeZone: 'UTC', // Force UTC
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Load objectives billboard
const objectivesPath = join(process.cwd(), 'src/content/now/objectives.md');
const objectivesSections = existsSync(objectivesPath)
  ? parseObjectives(readFileSync(objectivesPath, 'utf-8'))
  : null;

---

<BaseLayout title="Now" description="What I'm currently focused on.">
  <NavPill />
  <div class="container">
    <article class="now p3r-animate">
      <header class="now__header">
        <div class="now__header-rule" aria-hidden="true"></div>
        <div class="now__header-top">
          <h1 class="now__title">Now</h1>
          <p class="now__updated" title="Date shown in UTC">
            <span class="now__updated-icon" aria-hidden="true">◈</span>
            {lastUpdated}
          </p>
        </div>
        {latestPost.data.title && latestPost.data.title !== 'Now' && (
          <p class="now__entry-title">{latestPost.data.title}</p>
        )}
      </header>

      {objectivesSections && objectivesSections.length > 0 && (
        <ObjectivesBillboard sections={objectivesSections} />
      )}

      <div class="now__content prose">
        <Content />
      </div>

      <footer class="now__footer p3r-animate" style="--stagger-delay: 200ms;">
        <div class="now__footer-divider" aria-hidden="true"></div>
        <div class="now__footer-content">
          <span class="now__footer-label">Archive</span>
          <a href="/now/archive" class="now__archive-link">
            View past entries <span aria-hidden="true" class="now__archive-arrow">→</span>
          </a>
        </div>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  .now {
    max-width: 60ch;
    margin: 0 auto;
    padding-bottom: 80px; /* Space for floating nav */
  }

  /* Gradient rule — sweeps in before the title */
  .now__header-rule {
    height: 3px;
    background: linear-gradient(90deg, var(--color-gold) 0%, var(--color-gold-orange) 50%, transparent 100%);
    margin-bottom: var(--space-lg);
    animation: p3r-wipe-reveal 500ms var(--animation-easing) backwards;
    border-radius: 2px;
  }

  .now__header {
    margin-bottom: var(--space-xl);
  }

  .now__header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .now__title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    color: var(--color-gold);
    text-shadow:
      0 0 30px rgba(255, 229, 44, 0.4),
      0 0 60px rgba(255, 229, 44, 0.2);
    animation: p3r-animate-left 500ms var(--animation-easing) 100ms backwards;
  }

  .now__updated {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    background: var(--color-black);
    color: var(--color-gold);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-sm);
    border: var(--border-thin) solid var(--color-gold-dim);
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
    animation: p3r-animate 400ms var(--animation-easing) 300ms backwards;
  }

  .now__entry-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    animation: p3r-animate-left 500ms var(--animation-easing) 175ms backwards;
  }

  .now__updated-icon {
    color: var(--color-gold-dim);
    font-size: 0.85em;
  }

  /* Prose with left accent */
  .now__content {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-lg);
    border-left: var(--border-thick) solid var(--color-gold-dim);
  }

  .now__content p {
    margin-bottom: var(--space-lg);
  }

  .now__content p:last-child {
    margin-bottom: 0;
  }

  /* Footer */
  .now__footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
  }

  .now__footer-divider {
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--color-gold-dim) 40%, transparent 100%);
    margin-bottom: var(--space-lg);
    border-radius: 2px;
  }

  .now__footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .now__footer-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .now__archive-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background: var(--color-bg-elevated);
    border: var(--border-medium) solid var(--color-gold-dim);
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-gold);
    transition:
      background var(--transition-base),
      color var(--transition-base),
      border-color var(--transition-base),
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .now__archive-link:hover {
    background: var(--color-gold);
    color: var(--color-black);
    border-color: var(--color-gold);
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-hard);
  }

  .now__archive-arrow {
    transition: transform var(--transition-fast);
  }

  .now__archive-link:hover .now__archive-arrow {
    transform: translateX(3px);
  }

  .now__archive-link:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .now__header-rule,
    .now__title,
    .now__entry-title,
    .now__updated {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .now__header-top {
      flex-wrap: wrap;
    }
  }
</style>
