---
import { getCollection } from 'astro:content';
import { join } from 'path';
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoGrid from '../components/BentoGrid.astro';
import BentoTile from '../components/BentoTile.astro';
import { buildNovelTree } from '../utils/novel';

// Query all content collections for items with publishedAt dates
const notes = await getCollection('notes', ({ data }) => !data.draft && data.publishedAt);
const media = await getCollection('media', ({ data }) => !data.draft && data.publishedAt);
const showcase = await getCollection('showcase', ({ data }) => !data.draft && data.publishedAt);

// Query now collection for latest entry
const allNow = await getCollection('now', ({ data }) => !data.draft);
const latestNow = allNow.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)[0];

// Format month and year for now tile
const nowDate = latestNow?.data.publishedAt;
const nowMonthYearUTC = nowDate
  ? nowDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })
  : '';
const nowMonthYearLocal = nowDate
  ? nowDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : '';

const DEFAULT_EMBLEM = '/images/emblems/default.svg';

const effectiveDate = (e: { data: { updatedAt?: Date; publishedAt?: Date } }) =>
  new Date(e.data.updatedAt || e.data.publishedAt || 0).getTime();

// Recent entries with emblems for core tile thumbnails
const recentShowcase = showcase
  .filter(e => e.data.publishedAt)
  .sort((a, b) => effectiveDate(b) - effectiveDate(a))
  .slice(0, 3)
  .map(e => ({ href: `/showcase/${e.slug}`, emblem: e.data.emblem ?? DEFAULT_EMBLEM, title: e.data.title }));

const recentMedia = media
  .filter(e => e.data.publishedAt)
  .sort((a, b) => effectiveDate(b) - effectiveDate(a))
  .slice(0, 2)
  .map(e => ({ href: `/media/${e.slug}`, emblem: e.data.emblem ?? DEFAULT_EMBLEM, title: e.data.title }));

const recentNotes = notes
  .filter(e => e.data.publishedAt)
  .sort((a, b) => effectiveDate(b) - effectiveDate(a))
  .slice(0, 3)
  .map(e => ({ href: `/notes/${e.slug}`, title: e.data.title }));

// Find the most recently published/updated content
const allContent = [...notes, ...media, ...showcase];
const sorted = allContent.sort((a, b) => effectiveDate(b) - effectiveDate(a));

// Get entries with the most recent date for client-side randomization
const mostRecentDate = sorted[0] ? effectiveDate(sorted[0]) : null;
const sameDateEntries = mostRecentDate
  ? sorted.filter(entry => effectiveDate(entry) === mostRecentDate)
  : [];

// Novel — find most recently modified file date from MetaData.txt
const novelDir = join(process.cwd(), 'src/content/novel');
const novelTree = await buildNovelTree(novelDir);
let novelLastModified: Date | null = null;
let novelRecentFileTitle: string | null = null;
let novelRecentFolderTitle: string | null = null;
for (const folder of Object.values(novelTree)) {
  const allFiles = [
    ...folder.files.map(f => ({ file: f, folderTitle: folder.title })),
    ...Object.values(folder.subfolders).flatMap(s => s.files.map(f => ({ file: f, folderTitle: folder.title }))),
  ];
  for (const { file, folderTitle } of allFiles) {
    if (file.modified) {
      const d = new Date(file.modified);
      if (!isNaN(d.getTime()) && (!novelLastModified || d > novelLastModified)) {
        novelLastModified = d;
        novelRecentFileTitle = file.title;
        novelRecentFolderTitle = folderTitle;
      }
    }
  }
}
const novelLastModifiedISO = novelLastModified?.toISOString() ?? null;

// Prepare data for client-side randomization
const latestEntries = sameDateEntries.map(entry => ({
  title: entry.data.title,
  href: `/${entry.collection}/${entry.slug}`,
  publishedAt: entry.data.publishedAt!.toISOString(),
  updatedAt: entry.data.updatedAt?.toISOString(),
  emblem: entry.data.emblem ?? DEFAULT_EMBLEM,
}));
---

<BaseLayout title="Home" description="Fragments, media, and showcase.">
  <div class="container">
    <BentoGrid>
      <!-- Row 1: Title (4×1) + YouTube (1×1) + Now (1×1) -->
      <div class="title-tile p3r-animate-left">
        <div class="title-tile__inner">
          <div class="title-tile__rule title-tile__rule--top" aria-hidden="true"></div>
          <span class="title-tile__name">Ninjaruss</span>
          <div class="title-tile__rule title-tile__rule--bottom" aria-hidden="true"></div>
        </div>
        <p class="title-tile__description">Live without regret.</p>
      </div>

      <div class="image-tile image-tile--youtube p3r-animate" style="--stagger-delay: 100ms;">
        <a href="https://www.youtube.com/@Ninjaruss_" target="_blank" rel="noopener noreferrer">
          <img
            src="https://external-content.duckduckgo.com/iu/?u=https%3A%2F%2Fi.ytimg.com%2Fvi%2FHCc3Ol7adcw%2Fmaxresdefault.jpg&f=1&nofb=1&ipt=3af1979f6b60ed9a8bb7f3ff02d25d81b2b98005b38c7a5b9f2bc4d6f8bb3aa9"
            alt="Hero visual"
            class="image-tile__img"
          />
          <div class="image-tile__youtube-overlay">
            <svg class="image-tile__youtube-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
        </a>
      </div>

      <!-- Now tile — row 1 col 6 -->
      <BentoTile
        href="/now"
        variant="highlight"
        label="Now"
        title="Current Focus"
        description="Where am I at right now?"
      >
        <span class="now-date" title={`Local: ${nowMonthYearLocal}`}>
          <span class="now-dot" aria-hidden="true"></span>
          {nowMonthYearUTC}
          {nowMonthYearLocal !== nowMonthYearUTC ? ` — ${nowMonthYearLocal} locally` : ''}
        </span>
      </BentoTile>

      <!-- Rows 2-3: Showcase (3×2) + Notes (2×2) + Favorites (1×2) -->
      <BentoTile
        href="/showcase"
        variant="highlight"
        accent
        label="Showcase"
        title="What I'm Building"
        description="Stuff I've created and that I am currently working on."
        class="bento-tile--core bento-tile--span-3x2 showcase-tile"
      >
        {recentShowcase.length > 0 && (
          <div class="tile-emblems tile-emblems--highlight">
            {recentShowcase.map(entry => (
              <div class="tile-emblem" title={entry.title} data-href={entry.href} role="link" tabindex="0">
                <img src={entry.emblem} alt="" class="tile-emblem__img" loading="lazy" aria-hidden="true" />
              </div>
            ))}
          </div>
        )}
      </BentoTile>

      <BentoTile
        href="/notes"
        variant="dark"
        label="Notes"
        title="Reflections"
        description="An assortment of ideas I've been thinking about."
        class="bento-tile--core bento-tile--span-2x2 notes-tile"
      >
        {recentNotes.length > 0 && (
          <div class="tile-notes-list">
            {recentNotes.map(entry => (
              <div
                class="tile-note-link"
                data-href={entry.href}
                role="link"
                tabindex="0"
                title={entry.title}
              >
                {entry.title}
              </div>
            ))}
          </div>
        )}
      </BentoTile>

      <a
        id="kaima-tile"
        href="https://www.youtube.com/@kaima-mask"
        target="_blank"
        rel="noopener noreferrer"
        class="bento-tile bento-tile--full bento-tile--small bento-tile--dark bento-tile--interactive bento-tile--span-1x2 kaima-tile"
      >
        <div class="kaima-tile__body">
          <div class="kaima-tile__text">
            <div class="kaima-tile__name">KAIMA 悔魔</div>
            <div class="kaima-tile__desc">upcoming · session log</div>
          </div>
          <div
            id="kaima-watch-btn"
            class="kaima-watch-btn"
            role="link"
            tabindex="-1"
            aria-label="Watch live stream"
            data-href="https://www.youtube.com/@kaima-mask"
            hidden
          >
            <span class="kaima-watch-btn__dot"></span>
            Watch<br />Live
          </div>
        </div>
      </a>

      <!-- Rows 4-5: Media (2×2) + Latest (2×1) + Novel (1×2) + MAL/Spotify (stacked 1×1) -->
      <BentoTile
        href="/media"
        variant="dark"
        label="Media"
        title="Logbook"
        description="My thoughts on anime, manga, movies, and more — favorites included."
        class="bento-tile--core bento-tile--span-2x2 media-tile"
      >
        {recentMedia.length > 0 && (
          <div class="tile-emblems">
            {recentMedia.map(entry => (
              <div class="tile-emblem" title={entry.title} data-href={entry.href} role="link" tabindex="0">
                <img src={entry.emblem} alt="" class="tile-emblem__img" loading="lazy" aria-hidden="true" />
              </div>
            ))}
          </div>
        )}
      </BentoTile>

      {latestEntries.length > 0 && (
        <a
          id="latest-tile"
          href={latestEntries[0].href}
          class="bento-tile bento-tile--full bento-tile--small bento-tile--dark bento-tile--accent bento-tile--span-2x1"
          data-entries={JSON.stringify(latestEntries)}
        >
          <div class="latest-tile__inner">
            <div class="latest-tile__text">
              <div class="bento-tile__header">
                <span class="bento-tile__label">Latest</span>
                <h3 class="bento-tile__title" id="latest-title">{latestEntries[0].title}</h3>
              </div>
              <div class="bento-tile__footer">
                <span class="days-ago" id="latest-days-ago"></span>
              </div>
            </div>
            <div class="latest-tile__emblem-wrap">
              <img
                id="latest-emblem"
                src={latestEntries[0].emblem}
                alt=""
                class="latest-tile__emblem"
                aria-hidden="true"
              />
            </div>
          </div>
        </a>
      )}

      <!-- Novel tile — 1×2 -->
      <a
        href="/novel"
        class="bento-tile bento-tile--full bento-tile--small bento-tile--dark bento-tile--interactive bento-tile--span-1x2 novel-tile"
        id="novel-tile"
      >
        <div class="bento-tile__header">
          <span class="bento-tile__label">Novel</span>
          <h3 class="bento-tile__title">Remember Rain</h3>
        </div>
        {novelRecentFolderTitle && novelRecentFileTitle && (
          <p class="novel-tile__recent">
            <span class="novel-tile__folder">{novelRecentFolderTitle}</span>
            <span class="novel-tile__sep">›</span>
            <span class="novel-tile__file">{novelRecentFileTitle}</span>
          </p>
        )}
        <div class="bento-tile__footer">
          <span
            class="days-ago"
            id="novel-days-ago"
            data-novel-date={novelLastModifiedISO ?? ''}
          ></span>
        </div>
      </a>

      <a
        href="https://myanimelist.net/animelist/Ninjaruss_?status=7&order=4&order2=0"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-tile logo-tile--mal p3r-animate"
        style="--stagger-delay: 100ms;"
      >
        <img
          src="/images/logos/myanimelist.svg"
          alt="MyAnimeList"
          class="logo-tile__img"
        />
        <span class="logo-tile__label">MyAnimeList</span>
        <p class="logo-tile__description">Anime I've watched and rated based on personal enjoyment.</p>
      </a>

      <a
        href="https://open.spotify.com/playlist/6PYIeR2dXsbTrk47TqetSD?si=2b68cabcfc26451c"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-tile logo-tile--spotify p3r-animate"
        style="--stagger-delay: 150ms;"
      >
        <img
          src="/images/logos/spotify.svg"
          alt="Spotify Playlist"
          class="logo-tile__img"
        />
        <span class="logo-tile__label">Spotify</span>
        <p class="logo-tile__description">The bangers I listen to every day.</p>
      </a>
    </BentoGrid>
  </div>
</BaseLayout>

<style>
  .container {
    padding-top: var(--space-sm);
    padding-bottom: var(--space-md);
    position: relative;
  }

  .container::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: calc(var(--radius-lg) + 3px);
    padding: 3px;
    background: linear-gradient(90deg, #ff4040 0%, #ff6a1a 35%, #ffe52c 65%, #ff4040 100%);
    background-size: 300% 100%;
    /* Mask trick: show only the 3px padding ring, hide the center */
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 600ms ease;
    pointer-events: none;
    z-index: 100;
  }

  .container.is-live::before {
    opacity: 1;
    animation: live-border-flow 4s linear infinite;
  }

  @keyframes live-border-flow {
    0%   { background-position: 0% 0%; }
    100% { background-position: 300% 0%; }
  }

  /* Days ago indicator for Latest tile */
  .days-ago {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-gold-dim);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    border-left: 2px solid var(--color-gold-dim);
    padding-left: 6px;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  #latest-tile:hover .days-ago,
  #novel-tile:hover .days-ago {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  /* Optionally, make the local date more subtle */
  .now-date span.local {
    color: rgba(0, 0, 0, 0.5);
    font-size: 0.8em;
    margin-left: 0.25em;
  }

  /* Logo Tiles (MyAnimeList, Spotify) */
  .logo-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-bg-elevated);
    border: var(--border-medium) solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
    min-height: 80px;
  }

  .logo-tile:hover {
    transform: translate(-4px, -4px);
    border-color: var(--color-gold);
    box-shadow:
      4px 4px 0 rgba(255, 229, 44, 0.3),
      0 0 20px rgba(255, 229, 44, 0.15);
  }

  /* MAL brand accent — deep blue */
  .logo-tile--mal:hover {
    border-color: #2e51a2;
    box-shadow:
      4px 4px 0 rgba(46, 81, 162, 0.4),
      0 0 24px rgba(46, 81, 162, 0.25);
  }

  .logo-tile--mal:hover .logo-tile__label {
    color: #5a88d4;
  }

  /* Spotify brand accent — signature green */
  .logo-tile--spotify:hover {
    border-color: #1db954;
    box-shadow:
      4px 4px 0 rgba(29, 185, 84, 0.4),
      0 0 24px rgba(29, 185, 84, 0.25);
  }

  .logo-tile--spotify:hover .logo-tile__label {
    color: #1db954;
  }

  .logo-tile:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .logo-tile__img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .logo-tile__label {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    text-align: center;
  }

  .logo-tile:hover .logo-tile__label {
    color: var(--color-gold);
  }

  .logo-tile__description {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    line-height: 1.4;
    text-align: center;

    /* Hidden by default, revealed on hover with 400ms delay */
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition:
      opacity 200ms ease-out 400ms,
      max-height 300ms ease-out 0ms;
  }

  .logo-tile:hover .logo-tile__description {
    opacity: 1;
    max-height: 100px;
  }

  /* Instant hide on mouse out (remove delay) */
  .logo-tile:not(:hover) .logo-tile__description {
    transition-delay: 0ms;
  }

  /* ─── Title Tile ─────────────────────────────────────── */
  .title-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-black);
    /* Dot grid atmosphere */
    background-image: radial-gradient(circle, rgba(255, 229, 44, 0.07) 1px, transparent 1px);
    background-size: 22px 22px;
    border: var(--border-thick) solid var(--color-gold);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    grid-column: span 4;
    grid-row: span 1;
    box-shadow:
      var(--shadow-glow),
      inset 0 0 60px rgba(255, 229, 44, 0.04);
    overflow: hidden;
    opacity: 1;
    transition: opacity var(--transition-base);
  }

  .title-tile__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
    max-width: 320px;
  }

  /* Animated gold rules — shimmer sweep after initial reveal */
  .title-tile__rule {
    height: 2px;
    width: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-gold) 20%,
      var(--color-gold-orange) 50%,
      var(--color-gold) 80%,
      transparent 100%
    );
    background-size: 200% 100%;
    border-radius: 2px;
  }

  .title-tile__rule--top {
    animation:
      p3r-wipe-reveal 500ms var(--animation-easing) 0ms backwards,
      rule-shimmer 5s ease-in-out 1.2s infinite;
  }

  .title-tile__rule--bottom {
    animation:
      p3r-wipe-reveal 500ms var(--animation-easing) 300ms backwards,
      rule-shimmer 5s ease-in-out 2s infinite;
  }

  @keyframes rule-shimmer {
    0%, 100% { background-position: 200% 0; opacity: 0.7; }
    50% { background-position: -100% 0; opacity: 1; }
  }

  .title-tile__name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.02em;
    text-shadow:
      0 0 30px rgba(255, 229, 44, 0.6),
      0 0 60px rgba(255, 229, 44, 0.3);
    animation: p3r-animate-left 500ms var(--animation-easing) 100ms backwards;
  }

  /* Tagline: always subtly visible, sharpens on hover */
  .title-tile__description {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    line-height: 1.4;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.45;
    transition: opacity 300ms ease-out;
  }

  .title-tile:hover .title-tile__description {
    opacity: 1;
  }

  /* ─── Showcase Tile ───────────────────────────────────── */
  /* Background glyph — bolder */
  .tile-bg-glyph {
    position: absolute;
    bottom: -20px;
    right: -10px;
    font-family: var(--font-display);
    font-size: 9rem;
    line-height: 1;
    color: rgba(0, 0, 0, 0.12);
    pointer-events: none;
    user-select: none;
    z-index: 0;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .showcase-tile:hover .tile-bg-glyph {
    opacity: 0.18;
    transform: translate(-4px, -4px) scale(1.06) rotate(-3deg);
  }

  /* Subtle diagonal stripe on gold background */
  .showcase-tile {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 18px,
      rgba(0, 0, 0, 0.035) 18px,
      rgba(0, 0, 0, 0.035) 19px
    );
  }

  /* ─── Notes Tile ──────────────────────────────────────── */
  .notes-tile {
    position: relative;
    overflow: hidden;
    /* Notebook horizontal lines layered on the base bg */
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 27px,
      rgba(255, 229, 44, 0.045) 27px,
      rgba(255, 229, 44, 0.045) 28px
    );
  }

  /* Diagonal hatching on top */
  .notes-tile::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(255, 229, 44, 0.035) 10px,
      rgba(255, 229, 44, 0.035) 11px
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Notes tile fragment list */
  .tile-notes-list {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .tile-note-link {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: rgba(255, 229, 44, 0.5);
    padding: var(--space-xs) 0;
    border-top: 1px solid rgba(255, 229, 44, 0.08);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .tile-note-link::before {
    content: '→ ';
    opacity: 0.6;
  }

  .tile-note-link:hover {
    color: var(--color-gold);
  }

  .tile-note-link:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ─── Media Tile ──────────────────────────────────────── */
  .media-tile {
    /* Horizontal CRT scan-line texture */
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(255, 229, 44, 0.025) 3px,
      rgba(255, 229, 44, 0.025) 4px
    );
  }

  /* Larger emblems centered in filled footer area */
  .media-tile .tile-emblem {
    width: 96px;
    height: 96px;
    border: 2px solid var(--color-gold-dim);
  }

  .showcase-tile .tile-emblem {
    width: 80px;
    height: 80px;
  }

  /* ─── Now Tile ────────────────────────────────────────── */
  .now-date {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-black);
    text-transform: lowercase;
  }

  /* Radar ping dot */
  .now-dot {
    position: relative;
    display: inline-block;
    width: 9px;
    height: 9px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-black);
  }

  /* Two expanding rings for radar ping effect */
  .now-dot::before,
  .now-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid var(--color-black);
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .now-dot {
      animation: dot-breathe 2s ease-in-out infinite;
    }

    .now-dot::before {
      animation: radar-ping 2.4s ease-out 0.2s infinite;
    }

    .now-dot::after {
      animation: radar-ping 2.4s ease-out 1.2s infinite;
    }
  }

  @keyframes dot-breathe {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(0.75); }
  }

  @keyframes radar-ping {
    0% { transform: scale(0.6); opacity: 0.7; }
    100% { transform: scale(3); opacity: 0; }
  }

  @keyframes now-pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.65); }
  }

  /* ─── KAIMA Tile ─────────────────────────────────────── */
  .kaima-tile {
    text-decoration: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      background var(--transition-base);
  }

  .kaima-tile:not(.is-live):hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-hard);
  }

  .kaima-tile.is-live {
    border-color: #ff4040;
    background: #181212;
    box-shadow: 4px 4px 0 rgba(255, 64, 64, 0.35), 0 0 28px rgba(255, 64, 64, 0.12);
    animation: kaima-tile-pulse 2.5s ease-in-out infinite;
  }

  @keyframes kaima-tile-pulse {
    0%, 100% { box-shadow: 4px 4px 0 rgba(255, 64, 64, 0.35), 0 0 24px rgba(255, 64, 64, 0.12); }
    50%       { box-shadow: 4px 4px 0 rgba(255, 64, 64, 0.5),  0 0 40px rgba(255, 64, 64, 0.22); }
  }

  .kaima-tile__body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    width: 100%;
  }

  .kaima-tile__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .kaima-tile__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-muted);
    line-height: 1.1;
    transition: color var(--transition-fast);
  }

  .kaima-tile.is-live .kaima-tile__name {
    color: #c8c8c8;
  }

  .kaima-tile__desc {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    opacity: 0.5;
    transition: color var(--transition-fast);
  }

  .kaima-tile.is-live .kaima-tile__desc {
    color: #4a3535;
    opacity: 1;
  }

  /* Watch Live button — inside tile, right side */
  .kaima-watch-btn {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 52px;
    min-height: 52px;
    padding: 10px 6px;
    border-radius: 6px;
    background: #ff4040;
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.45rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 0 14px rgba(255, 64, 64, 0.5);
    animation: kaima-btn-breathe 1.5s ease-in-out infinite;
  }

  .kaima-watch-btn[hidden] {
    display: none;
  }

  @keyframes kaima-btn-breathe {
    0%, 100% { box-shadow: 0 0 10px rgba(255, 64, 64, 0.45); }
    50%       { box-shadow: 0 0 22px rgba(255, 64, 64, 0.85); }
  }

  .kaima-watch-btn__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    animation: kaima-dot-flash 1s ease-in-out infinite;
  }

  @keyframes kaima-dot-flash {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* Image Tile */
  .image-tile {
    grid-column: span 1;
    grid-row: span 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: var(--border-thick) solid var(--color-border-strong);
    background: var(--color-bg-elevated);
    position: relative;
    box-shadow: var(--shadow-hard);
    opacity: 1;
    transition:
      opacity var(--transition-base),
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      border-color var(--transition-fast);
  }

  .image-tile:hover {
    transform: translate(-4px, -4px);
    box-shadow: var(--shadow-hard-hover);
    border-color: var(--color-gold);
  }

  .image-tile:active {
    transform: translate(0, 0);
    box-shadow: var(--shadow-hard-sm);
  }

  .image-tile a {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .image-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter var(--transition-fast);
  }

  .image-tile:hover .image-tile__img {
    filter: brightness(0.8);
  }

  /* YouTube Overlay — cinematic gradient + centered icon */
  .image-tile__youtube-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Vignette from edges, darker at bottom */
    background:
      radial-gradient(ellipse at center, transparent 30%, rgba(0, 0, 0, 0.55) 100%),
      linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .image-tile--youtube:hover .image-tile__youtube-overlay {
    opacity: 1;
  }

  .image-tile__youtube-icon {
    width: 72px;
    height: 72px;
    color: #ffffff;
    filter:
      drop-shadow(0 0 12px rgba(255, 0, 0, 0.6))
      drop-shadow(0 2px 8px rgba(0, 0, 0, 0.8));
    transition: transform var(--transition-base);
  }

  .image-tile--youtube:hover .image-tile__youtube-icon {
    transform: scale(1.15);
  }

  /* Emblem thumbnail strip — used in core tile slots */
  .tile-emblems {
    display: flex;
    flex-direction: row;
    gap: var(--space-xs);
    align-items: center;
  }

  .tile-emblem {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-surface);
    cursor: pointer;
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .tile-emblem:hover {
    transform: scale(1.08);
    border-color: var(--color-gold);
    box-shadow: 0 0 12px rgba(255, 229, 44, 0.3);
  }

  .tile-emblem:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .tile-emblem__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.85;
    transition: opacity var(--transition-fast);
  }

  .bento-tile:hover .tile-emblem__img {
    opacity: 1;
  }

  /* Highlight variant: emblems on gold background need dark borders */
  .tile-emblems--highlight .tile-emblem {
    border-color: rgba(0, 0, 0, 0.25);
    background: var(--color-black);
  }

  .tile-emblems--highlight .tile-emblem__img {
    opacity: 0.9;
  }

  .bento-tile--highlight:hover .tile-emblems--highlight .tile-emblem {
    border-color: rgba(0, 0, 0, 0.5);
  }

  /* Latest tile — flex row for text + emblem layout */
  .latest-tile__inner {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    justify-content: space-between;
    flex: 1;
    gap: var(--space-sm);
  }

  .latest-tile__text {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 1;
    min-width: 0;
  }

  .latest-tile__emblem-wrap {
    flex-shrink: 0;
    width: 56px;
    display: flex;
    align-items: stretch;
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .latest-tile__emblem {
    width: 100%;
    height: 100%;
    border-radius: var(--radius-sm);
    object-fit: cover;
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-surface);
    opacity: 0.85;
    transition:
      opacity var(--transition-fast),
      border-color var(--transition-fast);
  }

  /* Novel tile — center title and date vertically, no dead gap */
  .novel-tile {
    justify-content: center;
    gap: var(--space-md);
  }

  .novel-tile__recent {
    margin: 0;
    font-size: 0.7rem;
    color: var(--color-text-muted, rgba(245, 245, 245, 0.45));
    display: flex;
    align-items: center;
    gap: 0.3em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .novel-tile__sep {
    opacity: 0.5;
  }

  .novel-tile__file {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #latest-tile:hover .latest-tile__emblem {
    opacity: 1;
    border-color: var(--color-gold);
  }

  /* Reduced Motion Support */
  @media (prefers-reduced-motion: reduce) {
    .logo-tile__description {
      transition: opacity 100ms ease-out 0ms;
    }

    .logo-tile:hover .logo-tile__description {
      transition-delay: 0ms;
    }

    .title-tile__rule--top,
    .title-tile__rule--bottom,
    .title-tile__name {
      animation: none;
    }

    .tile-emblem,
    .tile-emblem__img,
    .latest-tile__emblem {
      transition: none;
    }

    .kaima-tile.is-live          { animation: none; }
    .kaima-watch-btn              { animation: none; }
    .kaima-watch-btn__dot         { animation: none; }
    .container.is-live::before   { animation: none; background-position: 0% 0%; }
  }

  @media (max-width: 768px) {
    .title-tile {
      grid-column: span 2;
      padding: var(--space-lg);
    }

    .title-tile__name {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
    }

    .image-tile {
      grid-column: span 2;
      min-height: 200px;
    }

    .image-tile__youtube-icon {
      width: 48px;
      height: 48px;
    }

    .tile-emblem {
      width: 56px;
      height: 56px;
    }

    .latest-tile__emblem-wrap {
      width: 48px;
    }
  }

  @media (max-width: 480px) {
    .title-tile {
      grid-column: span 1;
    }

    .title-tile__name {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    .image-tile {
      grid-column: span 1;
    }

    .image-tile__youtube-icon {
      width: 40px;
      height: 40px;
    }

    .tile-emblem {
      width: 44px;
      height: 44px;
    }

    .latest-tile__emblem-wrap {
      width: 44px;
    }
  }
</style>

<script>
  import { parseYouTubeLiveResponse } from '../utils/liveStatus';

  const YOUTUBE_API_KEY = import.meta.env.PUBLIC_YOUTUBE_API_KEY as string;
  const CHANNEL_ID = 'UCjgsr8Oki5_CPwx53tdnwCg';
  const CHANNEL_URL = 'https://www.youtube.com/@kaima-mask';

  let liveInterval: ReturnType<typeof setInterval> | undefined;

  async function checkYouTubeLive(): Promise<void> {
    if (!YOUTUBE_API_KEY) {
      console.error('[live] PUBLIC_YOUTUBE_API_KEY is not set — live check skipped');
      return;
    }
    try {
      const url =
        `https://www.googleapis.com/youtube/v3/search` +
        `?part=id&channelId=${CHANNEL_ID}&type=video&eventType=live&key=${YOUTUBE_API_KEY}`;
      const res = await fetch(url);
      if (!res.ok) {
        const body = await res.text();
        console.error(`[live] YouTube API error ${res.status}:`, body);
        applyLiveState(false, null);
        return;
      }
      const data: unknown = await res.json();
      const { isLive, videoId } = parseYouTubeLiveResponse(data);
      console.log('[live] check result:', { isLive, videoId });
      applyLiveState(isLive, videoId);
    } catch (err) {
      console.error('[live] fetch failed:', err);
      applyLiveState(false, null);
    }
  }

  function applyLiveState(isLive: boolean, videoId: string | null): void {
    const tile = document.getElementById('kaima-tile') as HTMLAnchorElement | null;
    const container = document.querySelector<HTMLElement>('.container');
    const watchBtn = document.getElementById('kaima-watch-btn') as HTMLElement | null;

    if (!tile || !container) return;

    if (isLive) {
      tile.classList.add('is-live');
      container.classList.add('is-live');
      if (watchBtn) {
        watchBtn.hidden = false;
        watchBtn.dataset.href = videoId
          ? `https://www.youtube.com/watch?v=${videoId}`
          : CHANNEL_URL;
      }
    } else {
      tile.classList.remove('is-live');
      container.classList.remove('is-live');
      if (watchBtn) {
        watchBtn.hidden = true;
        watchBtn.dataset.href = CHANNEL_URL;
      }
    }
  }

  function startLivePolling(): void {
    stopLivePolling();
    checkYouTubeLive();
    liveInterval = setInterval(checkYouTubeLive, 300_000);
  }

  function stopLivePolling(): void {
    if (liveInterval !== undefined) {
      clearInterval(liveInterval);
      liveInterval = undefined;
    }
  }

  // Initialize Latest tile - runs on initial load and after view transitions
  function initializeLatestTile() {
    const latestTile = document.getElementById('latest-tile') as HTMLAnchorElement | null;
    if (latestTile) {
      const entries = JSON.parse(latestTile.dataset.entries || '[]');
      if (entries.length > 0) {
        // Pick a random entry
        const entry = entries[Math.floor(Math.random() * entries.length)];

        // Update tile
        latestTile.href = entry.href;
        const titleEl = document.getElementById('latest-title');
        if (titleEl) titleEl.textContent = entry.title;

        // Update emblem
        const emblemEl = document.getElementById('latest-emblem') as HTMLImageElement | null;
        if (emblemEl && entry.emblem) emblemEl.src = entry.emblem;

        // Calculate "X days ago"
        const daysAgoEl = document.getElementById('latest-days-ago');
        if (daysAgoEl) {
          const today = new Date();
          const publishedDate = new Date(entry.updatedAt || entry.publishedAt);
          const todayUTC = Date.UTC(today.getFullYear(), today.getMonth(), today.getDate());
          const publishedUTC = Date.UTC(publishedDate.getUTCFullYear(), publishedDate.getUTCMonth(), publishedDate.getUTCDate());
          const diffDays = Math.floor((todayUTC - publishedUTC) / (1000 * 60 * 60 * 24));

          if (diffDays === 0) daysAgoEl.textContent = 'today';
          else if (diffDays === 1) daysAgoEl.textContent = 'yesterday';
          else daysAgoEl.textContent = `${diffDays} days ago`;
        }
      }
    }
  }

  // Initialize Novel tile days-ago counter
  function initializeNovelTile() {
    const el = document.getElementById('novel-days-ago') as HTMLElement | null;
    if (!el) return;
    const isoDate = el.dataset.novelDate;
    if (!isoDate) return;

    const today = new Date();
    const modDate = new Date(isoDate);
    const todayUTC = Date.UTC(today.getFullYear(), today.getMonth(), today.getDate());
    const modUTC = Date.UTC(modDate.getUTCFullYear(), modDate.getUTCMonth(), modDate.getUTCDate());
    const diffDays = Math.floor((todayUTC - modUTC) / (1000 * 60 * 60 * 24));

    if (diffDays === 0) el.textContent = 'updated today';
    else if (diffDays === 1) el.textContent = 'updated yesterday';
    else el.textContent = `updated ${diffDays} days ago`;
  }

  // Emblem click navigation — handles data-href elements inside <a> tiles
  function initializeEmblemLinks() {
    document.querySelectorAll<HTMLElement>('.tile-emblem[data-href], .tile-note-link[data-href]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        window.location.href = el.dataset.href!;
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          e.stopPropagation();
          window.location.href = el.dataset.href!;
        }
      });
    });
  }

  function initializeKaimaWatchBtn(): void {
    const btn = document.getElementById('kaima-watch-btn');
    if (!btn) return;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const href = btn.dataset.href;
      if (href) window.open(href, '_blank', 'noopener,noreferrer');
    });
  }

  // Mouse-tracking 3D tilt for all tile types
  function initializeTilt() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!window.matchMedia('(hover: hover)').matches) return;

    const SELECTOR = '.bento-tile--interactive, .logo-tile, .image-tile, .title-tile';
    const MAX_TILT = 6;

    document.querySelectorAll<HTMLElement>(SELECTOR).forEach(tile => {
      let rafId: number;

      tile.addEventListener('mousemove', (e) => {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          const rect = tile.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const rx = ((e.clientY - cy) / (rect.height / 2)) * -MAX_TILT;
          const ry = ((e.clientX - cx) / (rect.width / 2)) * MAX_TILT;
          tile.style.transform = `perspective(700px) rotateX(${rx}deg) rotateY(${ry}deg) translate(-4px, -4px)`;
        });
      });

      tile.addEventListener('mouseleave', () => {
        cancelAnimationFrame(rafId);
        tile.style.transform = '';
      });
    });
  }

  // Run on initial page load
  initializeLatestTile();
  initializeNovelTile();
  initializeEmblemLinks();
  initializeKaimaWatchBtn();
  initializeTilt();
  startLivePolling();

  // Run after each view transition navigation
  document.addEventListener('astro:page-load', () => {
    initializeLatestTile();
    initializeNovelTile();
    initializeEmblemLinks();
    initializeKaimaWatchBtn();
    initializeTilt();
    startLivePolling();
  });

  // Clean up interval before navigating away
  document.addEventListener('astro:before-preparation', stopLivePolling);
</script>
