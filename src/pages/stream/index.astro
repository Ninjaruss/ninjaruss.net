---
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  tallyStats,
  buildRadarPoints,
  buildGuidePoints,
  parseQuestMenu,
  parseStreamIdeas,
  STAT_ORDER,
  scaleAllTallies,
  STAT_CEILING,
} from '../../utils/stream';
import '../../styles/stream.css';

const STAT_META: Record<string, { color: string; tagline: string; phrase: string; keywords: string; emblem: string; silFilter: string }> = {
  Determination: {
    color: '#ff4040', tagline: 'The will to continue',
    phrase: 'Pierce the heavens.', keywords: 'Push. Guts. Resolve.',
    emblem: '/images/emblems/determination.png', silFilter: 'sil-det',
  },
  Insight: {
    color: '#4ab0ff', tagline: 'Seeing through the noise',
    phrase: 'Clear Mind, Accel Synchro.', keywords: 'Perceive. Focus. Transcend.',
    emblem: '/images/emblems/insight.png', silFilter: 'sil-ins',
  },
  Chaos: {
    color: '#2dd4bf', tagline: 'Embracing the unexpected',
    phrase: 'Into the dark without a torch.', keywords: 'Risk. Fall. Rise.',
    emblem: '/images/emblems/chaos.png', silFilter: 'sil-cha',
  },
  Sincerity: {
    color: '#ffe52c', tagline: 'Meaning what you say',
    phrase: 'No mask.', keywords: 'Heart. Speak true. Trust.',
    emblem: '/images/emblems/sincerity.png', silFilter: 'sil-sin',
  },
  Expression: {
    color: '#a855f7', tagline: 'Making something from nothing',
    phrase: 'So the world will not forget.', keywords: 'Craft. Create. Soul.',
    emblem: '/images/emblems/expression.png', silFilter: 'sil-exp',
  },
};

const streamEntries = await getCollection('stream', ({ data }) => !data.draft);
const socialLinks   = await getCollection('social-links', ({ data }) => !data.draft);

streamEntries.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
socialLinks.sort((a, b) => b.data.rank - a.data.rank);

const bondsJson = JSON.stringify(
  socialLinks.map(link => ({
    name:            link.data.name,
    arcana:          link.data.arcana,
    affinity:        link.data.affinity,
    rank:            link.data.rank,
    stat:            link.data.stat ?? null,
    statColor:       link.data.stat ? (STAT_META[link.data.stat]?.color ?? null) : null,
    reachedDate:     link.data.reachedDate ?? null,
    lore:            link.data.lore ?? null,
    lastSession:     link.data.lastSession ?? null,
    lastInteraction: link.data.lastInteraction ?? null,
    img:             link.data.img ?? null,
  }))
);

const recentTallies = tallyStats(streamEntries, 'recent');
const allTallies    = tallyStats(streamEntries, 'all');
const recentMax     = Math.max(1, ...Object.values(recentTallies).map(v => v ?? 0));
const allScaled     = scaleAllTallies(allTallies);

// Radar geometry — center 200,200, radius 140; viewBox tight around labels/counts (-40,-65 → 460,395)
const CX = 200, CY = 200, R = 140;
const TEXT_R = R + 52;

const recentPoints = buildRadarPoints(recentTallies, recentMax,    CX, CY, R);
const allPoints    = buildRadarPoints(allScaled,     STAT_CEILING, CX, CY, R);
const guides       = [0.25, 0.5, 0.75, 1].map(f => buildGuidePoints(f, CX, CY, R));

const axes = STAT_ORDER.map((_, i) => {
  const angle = (-90 + i * 72) * (Math.PI / 180);
  return {
    x2: (CX + R * Math.cos(angle)).toFixed(2),
    y2: (CY + R * Math.sin(angle)).toFixed(2),
  };
});

const statVertices = STAT_ORDER.map((stat, i) => {
  const angle = (-90 + i * 72) * (Math.PI / 180);
  const vx = +(CX + R * Math.cos(angle)).toFixed(2);
  const vy = +(CY + R * Math.sin(angle)).toFixed(2);
  const tx = +(CX + TEXT_R * Math.cos(angle)).toFixed(2);
  const ty = +(CY + TEXT_R * Math.sin(angle)).toFixed(2);
  const meta = STAT_META[stat];
  const anchor = vx < CX - 10 ? 'end' : vx > CX + 10 ? 'start' : 'middle';
  const clipId = `clip-${stat.toLowerCase().slice(0, 3)}`;
  return { stat, vx, vy, tx, ty, meta, anchor, clipId };
});

const questRaw = readFileSync(join(process.cwd(), 'src/content/stream/_quests.md'), 'utf-8');
const questSections  = parseQuestMenu(questRaw);
const streamIdeas    = parseStreamIdeas(questRaw);
const currentObjective = questSections.find(s => s.category === 'Active Quests')?.quests[0] ?? null;

// Current date for the date strip
const now = new Date();
const dayNames  = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const dateDow   = dayNames[now.getUTCDay()];
const dateDay   = now.getUTCDate();
const dateMonth = `${monthNames[now.getUTCMonth()]} ${now.getUTCFullYear()}`;

const recentData = JSON.stringify(recentTallies);
const allData    = JSON.stringify(allTallies);

// Hex color to SVG feColorMatrix filter values
function hexToSilMatrix(hex: string, r: number, g: number, b: number): string {
  return `0 0 0 0 ${(r/255).toFixed(3)}  0 0 0 0 ${(g/255).toFixed(3)}  0 0 0 0 ${(b/255).toFixed(3)}  -2 0 0 0 1.5`;
}

const SIL_FILTERS: Record<string, { id: string; matrix: string }> = {
  Determination: { id: 'sil-det', matrix: hexToSilMatrix('#ff4040', 255, 64,  64)  },
  Insight:       { id: 'sil-ins', matrix: hexToSilMatrix('#4ab0ff',  74, 176, 255) },
  Expression:    { id: 'sil-exp', matrix: hexToSilMatrix('#a855f7', 168, 85,  247) },
  Sincerity:     { id: 'sil-sin', matrix: hexToSilMatrix('#ffe52c', 255, 229, 44)  },
  Chaos:         { id: 'sil-cha', matrix: hexToSilMatrix('#2dd4bf',  45, 212, 191) },
};

function colorBg(hex: string, a: number): string {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
}
---

<BaseLayout title="Stream" description="Velvet Room session archive for the ninjaruss_ Twitch stream.">
  <div id="slash"><div class="slash-blade" id="blade"></div></div>

  <div class="stream-page">

    <!-- Sidebar -->
    <div class="s-sidebar" id="sidebar">
      <a href="/" class="s-logo">Ninjaruss</a>
      <div class="s-tabs" id="tab-list" role="tablist">
        <div class="s-tab-indicator" id="tab-indicator"></div>
        <button class="s-tab active" data-tab="status"  role="tab" aria-selected="true">Status</button>
        <button class="s-tab"        data-tab="journal" role="tab" aria-selected="false">Journal</button>
        <button class="s-tab"        data-tab="bonds"   role="tab" aria-selected="false">Bonds</button>
        <button class="s-tab"        data-tab="mailbox" role="tab" aria-selected="false">Mailbox</button>
      </div>
    </div>

    <!-- Right content area -->
    <div class="s-content" id="content-area">

      <div class="s-header">
        <div class="s-header-title">Stream Log</div>
        <a class="s-live" href="https://www.twitch.tv/ninjaruss_" target="_blank" rel="noopener">
          <div class="s-live-dot"></div>Live
        </a>
      </div>

      <div class="s-shell">

        <!-- VN Sprite -->
        <div class="s-sprite" aria-hidden="true">
          <img src="/images/stream/portrait.png" alt="" id="portrait" />
        </div>

        <div class="s-main">

          <!-- ── STATUS ─────────────────────────────────────── -->
          <div class="s-panel active" id="panel-status" role="tabpanel">

            <!-- Date + Objective strip -->
            <div class="s-date-strip">
              <div class="s-date-block">
                <div class="s-date-day">{dateDow}</div>
                <div class="s-date-num">{dateDay}</div>
                <div class="s-date-month">{dateMonth}</div>
              </div>
              <div class="s-objective">
                <div class="s-obj-label">Current Objective</div>
                <div class="s-obj-text">{currentObjective ?? 'No active quest'}</div>
              </div>
            </div>

            <!-- Radar -->
            <div class="s-radar-container">
              <div class="s-mode-toggle">
                <button class="s-toggle-btn active" data-mode="recent">Recent (10)</button>
                <button class="s-toggle-btn"        data-mode="all">All Time</button>
              </div>

              <div id="stream-tally-data" data-recent={recentData} data-all={allData} hidden></div>

              <svg viewBox="-40 -65 500 460" aria-label="Stat radar chart" id="radar-svg">
                <defs>
                  <filter id="vglow">
                    <feGaussianBlur stdDeviation="4" result="b"/>
                    <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  {Object.entries(SIL_FILTERS).map(([, f]) => (
                    <filter id={f.id} color-interpolation-filters="sRGB" x="-10%" y="-10%" width="120%" height="120%">
                      <feColorMatrix type="saturate" values="0" result="g"/>
                      <feColorMatrix in="g" type="matrix" values={f.matrix}/>
                    </filter>
                  ))}
                  {statVertices.map(({ clipId, vx, vy }) => (
                    <clipPath id={clipId}>
                      <circle cx={vx} cy={vy} r="18"/>
                    </clipPath>
                  ))}
                </defs>

                <g id="radar-layer-bg">
                  {guides.map(pts => <polygon class="s-radar-guide" points={pts}/>)}
                  {axes.map(ax => <line class="s-radar-axis" x1={CX} y1={CY} x2={ax.x2} y2={ax.y2}/>)}

                  <polygon id="radar-all"    class="s-radar-poly-all"    points={allPoints}/>
                  <polygon id="radar-recent" class="s-radar-poly-recent" points={recentPoints}/>
                </g>

                <g id="radar-layer-vertices">
                {statVertices.map(({ stat, vx, vy, tx, ty, meta, anchor, clipId }) => {
                  const count = recentTallies[stat as (typeof STAT_ORDER)[number]] ?? 0;
                  const sil = SIL_FILTERS[stat];
                  const numAnchor = anchor;
                  const numX = tx;
                  const numY = ty - 20;
                  return (
                    <g class="radar-vertex" data-stat={stat} style={`--stat-color: ${meta.color}`}>
                      <rect
                        x={anchor === 'end'   ? tx - 160 : anchor === 'start' ? tx : tx - 80}
                        y={ty - 60} width="160" height="80"
                        fill="transparent"
                      />
                      <circle class="v-dot-small" cx={vx} cy={vy} r="7" fill={meta.color}/>
                      <text x={numX} y={numY} text-anchor={numAnchor}
                            font-family="system-ui,sans-serif" font-size="34" font-weight="900"
                            fill={meta.color} stroke="#060608" stroke-width="6" paint-order="stroke fill"
                            data-vertex-count={stat}>{count}</text>
                      <text x={tx} y={ty} text-anchor={anchor}
                            font-family="monospace" font-size="12" font-weight="700"
                            fill={meta.color} stroke="#060608" stroke-width="4" paint-order="stroke fill"
                            letter-spacing="1">{stat.toUpperCase()}</text>
                      <text class="v-keywords" x={tx} y={ty + 16} text-anchor={anchor}
                            font-family="monospace" font-size="10"
                            fill={colorBg(meta.color, 0.5)} stroke="#060608" stroke-width="3" paint-order="stroke fill">
                        {meta.keywords}
                      </text>
                      <text class="v-phrase" x={tx} y={ty + 16} text-anchor={anchor}
                            font-family="monospace" font-size="10"
                            fill={colorBg(meta.color, 0.9)} stroke="#060608" stroke-width="3" paint-order="stroke fill">
                        {meta.phrase}
                      </text>
                      <g class="v-emblem-large">
                        <circle class="v-emblem-backdrop" cx={vx} cy={vy} r="19" fill="#111111"/>
                        <circle class="v-emblem-ring" cx={vx} cy={vy} r="20" fill={colorBg(meta.color, 0.08)} stroke={meta.color} stroke-width="1.5"/>
                        <image href={meta.emblem} x={vx - 18} y={vy - 18} width="36" height="36"
                               clip-path={`url(#${clipId})`} filter={`url(#${sil.id})`}
                               preserveAspectRatio="xMidYMid slice"/>
                      </g>
                    </g>
                  );
                })}
                </g>
              </svg>
            </div>
          </div>

          <!-- ── JOURNAL ─────────────────────────────────────── -->
          <div class="s-panel" id="panel-journal" role="tabpanel">

            <div class="j-streams">
              <div class="j-section-header">
                <div class="j-section-label">Potential Streams</div>
                <div class="j-section-rule"></div>
                <div class="j-section-sub">click a stat to filter the log</div>
              </div>

              {STAT_ORDER.map(stat => {
                const meta  = STAT_META[stat];
                const ideas = streamIdeas[stat] ?? [];
                const glow  = colorBg(meta.color, 0.4);
                return (
                  <div class="j-stream-strip" data-stat={stat} style={`--strip-color:${meta.color}`}>
                    <div class="j-strip-label">
                      <div class="j-stat-dot" style={`background:${meta.color};box-shadow:0 0 5px ${glow}`}></div>
                      <div class="j-stat-name-sm" style={`color:${meta.color}`}>{stat}</div>
                    </div>
                    <div class="j-strip-ideas">
                      {ideas.map(idea => (
                        <span class="j-idea-pill" style={`color:${meta.color};border-color:${colorBg(meta.color, 0.25)}`}>
                          {idea}
                        </span>
                      ))}
                    </div>
                    <span class="j-strip-clear">× clear</span>
                  </div>
                );
              })}
            </div>

            <div class="j-log">
              <div class="j-log-top">
                <div class="j-section-label" id="log-label">Session Log</div>
              </div>
              <div class="j-log-list" id="log-list">
                {streamEntries.map(entry => {
                  const d   = entry.data.publishedAt;
                  const dow = dayNames[d.getUTCDay()];
                  const day = d.getUTCDate();
                  const mon = monthNames[d.getUTCMonth()];
                  return (
                    <div class="j-entry" data-stats={JSON.stringify(entry.data.stats)}>
                      <div class="j-entry-date-block">
                        <div class="j-entry-dow">{dow}</div>
                        <div class="j-entry-day-num">{day}</div>
                        <div class="j-entry-month">{mon}</div>
                      </div>
                      <div class="j-entry-body">
                        <div class="j-entry-title">{entry.data.title}</div>
                        <div class="j-entry-summary">{entry.data.summary}</div>
                        <div class="j-entry-chips">
                          {entry.data.stats.map(stat => {
                            const m = STAT_META[stat];
                            return (
                              <span class="j-chip" style={`color:${m?.color};border-color:${colorBg(m?.color ?? '#888', 0.3)};background:${colorBg(m?.color ?? '#888', 0.08)}`}>
                                {stat}
                              </span>
                            );
                          })}
                        </div>
                        {entry.data.memorable && (
                          <div class="j-entry-memo">{entry.data.memorable}</div>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>

          <!-- ── BONDS ────────────────────────────────────────── -->
          <div class="s-panel" id="panel-bonds" role="tabpanel">

            <div class="bonds-list-col">
              <div class="bonds-header">
                <span class="s-panel-label">Bonds · {socialLinks.length}</span>
              </div>
              <div class="bonds-list">
                {socialLinks.map(link => {
                  const statColor  = link.data.stat ? STAT_META[link.data.stat]?.color : null;
                  const colorBorder = statColor ? colorBg(statColor, 0.3)  : '#2a2a2a';
                  const colorBgVal  = statColor ? colorBg(statColor, 0.06) : 'rgba(255,255,255,0.04)';
                  const colorGlow   = statColor ? colorBg(statColor, 0.1)  : 'transparent';
                  const numerals    = ['I','II','III','IV','V'];
                  const rankLabel   = link.data.rank > 0 ? `RANK ${numerals[link.data.rank - 1] ?? link.data.rank}` : 'RANK —';
                  return (
                    <div class="bond-row" data-bond={link.data.name}
                         style={statColor ? `--bd-row-color:${statColor}` : ''}>
                      <div class="bond-emblem-col">
                        <div class="bond-emblem-wrap"
                             style={`--bond-color-border:${colorBorder};--bond-color-bg:${colorBgVal};--bond-color-glow:${colorGlow}`}>
                          {link.data.img
                            ? <img class="bond-img" src={link.data.img} alt="" />
                            : link.data.stat && STAT_META[link.data.stat]
                              ? <img class="bond-img" src={STAT_META[link.data.stat].emblem} alt="" />
                              : null
                          }
                        </div>
                      </div>
                      <div class="bond-info">
                        <div class="bond-arcana-label">{link.data.arcana}</div>
                        <div class="bond-name" style={statColor ? `color:${statColor}` : ''}>{link.data.name}</div>
                        <div class="bond-affinity">{link.data.affinity}</div>
                      </div>
                      <div class="bond-rank-col">
                        <div class="bond-rank-numeral" style={statColor ? `color:${statColor}` : ''}>{rankLabel}</div>
                        <div class="bond-rank-pips">
                          {Array.from({ length: 5 }, (_, i) => (
                            <span class="bond-pip" style={i < link.data.rank && statColor
                              ? `background:${statColor};border-color:${statColor};box-shadow:0 0 5px ${colorBg(statColor, 0.5)}`
                              : ''}/>
                          ))}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            <!-- Slide-in detail panel -->
            <div class="bond-detail-panel">
              <div class="bd-inner">
                <div class="bd-header">
                  <button class="bd-close" id="bond-detail-close" aria-label="Close">✕</button>
                  <div class="bd-emblem" id="bd-emblem">
                    <img id="bd-img" alt="" />
                  </div>
                  <div class="bd-arcana"   id="bd-arcana"></div>
                  <div class="bd-name"     id="bd-name"></div>
                  <div class="bd-affinity" id="bd-affinity"></div>
                  <div class="bd-stat-badge" id="bd-stat-badge">
                    <div class="bd-stat-dot"  id="bd-stat-dot"></div>
                    <span class="bd-stat-text" id="bd-stat-text"></span>
                  </div>
                  <div class="bd-rank-row">
                    <div class="bd-rank-label" id="bd-rank-label"></div>
                    <div class="bd-rank-pips" id="bd-rank-pips">
                      {Array.from({ length: 5 }, () => <span class="bd-pip-d"></span>)}
                    </div>
                  </div>
                  <div class="bd-rank-date" id="bd-rank-date"></div>
                </div>
                <div class="bd-section">
                  <div class="bd-section-label">About</div>
                  <div class="bd-lore" id="bd-lore"></div>
                </div>
                <div class="bd-section">
                  <div class="bd-section-label">Last Session</div>
                  <div class="bd-memory"      id="bd-memory"></div>
                  <div class="bd-memory-when" id="bd-memory-when"></div>
                </div>
              </div>
            </div>

            <div id="bonds-data" data-bonds={bondsJson} hidden></div>
          </div>

          <!-- ── MAILBOX ────────────────────────────────────── -->
          <div class="s-panel" id="panel-mailbox" role="tabpanel">
            <div class="mail-inner">
              <div class="mail-title">Mailbox</div>
              <div class="mail-sub">Send mail to be read on stream</div>
              <a href=`mailto:${'mailbox'}@${'ninjaruss.net'}` class="mail-address">{'mailbox'}@{'ninjaruss.net'}</a>
            </div>
          </div>

        </div>{/* s-main */}
      </div>{/* s-shell */}
    </div>{/* s-content */}
  </div>{/* stream-page */}
</BaseLayout>

<script>
  /* ── Live detection (Twitch + YouTube) ───────────────── */
  async function checkLiveStatus(): Promise<void> {
    try {
      const res = await fetch('/api/live-status');
      if (!res.ok) return;
      const { live } = await res.json() as { live: boolean };
      document.querySelector('.s-live')?.classList.toggle('is-live', live);
      if (live) document.title = '🔴 LIVE — ninjaruss_';
    } catch { /* non-critical */ }
  }
  checkLiveStatus();
  setInterval(checkLiveStatus, 300_000);

  /* ── DOM init ─────────────────────────────────────────── */
  document.addEventListener('astro:page-load', () => {
    const tabs      = document.querySelectorAll<HTMLButtonElement>('.s-tab');
    const panels    = document.querySelectorAll<HTMLElement>('.s-panel');
    const indicator = document.getElementById('tab-indicator');
    const blade     = document.getElementById('blade');
    const portrait  = document.getElementById('portrait');

    if (!tabs.length) return;

    let current = 'status';
    let busy    = false;
    let activeStrip: HTMLElement | null = null;

    function moveIndicator(tabEl: HTMLElement): void {
      if (!indicator) return;
      const listRect = document.getElementById('tab-list')!.getBoundingClientRect();
      const tabRect  = tabEl.getBoundingClientRect();
      indicator.style.top    = `${tabRect.top - listRect.top}px`;
      indicator.style.height = `${tabRect.height}px`;
    }

    function getItems(panelEl: HTMLElement): HTMLElement[] {
      return [...panelEl.querySelectorAll<HTMLElement>('.j-stream-strip, .j-entry, .bond-row')];
    }

    function exitItems(panelEl: HTMLElement, stagger = 28): number {
      const items = getItems(panelEl);
      items.forEach((item, i) => {
        item.style.animation = 'none';
        item.style.opacity   = '1';
        void (item as HTMLElement & { offsetWidth: number }).offsetWidth;
        item.style.animation = `itemExit 0.18s ease ${i * stagger}ms forwards`;
      });
      return items.length * stagger + 180;
    }

    function enterItems(panelEl: HTMLElement, delay = 0, stagger = 50): void {
      const items = getItems(panelEl);
      items.forEach((item, i) => {
        item.style.opacity   = '0';
        item.style.animation = 'none';
        void (item as HTMLElement & { offsetWidth: number }).offsetWidth;
        item.style.animation = `itemEnter 0.32s cubic-bezier(0.16,1,0.3,1) ${delay + i * stagger}ms forwards`;
        item.addEventListener('animationend', () => {
          item.style.opacity   = '';
          item.style.animation = '';
        }, { once: true });
      });
    }

    function fireSlash(): void {
      if (!blade) return;
      blade.classList.remove('slash-go');
      void (blade as HTMLElement & { offsetWidth: number }).offsetWidth;
      blade.classList.add('slash-go');
      blade.addEventListener('animationend', () => blade.classList.remove('slash-go'), { once: true });
    }

    function reactPortrait(): void {
      if (!portrait) return;
      portrait.style.animation = 'none';
      void (portrait as HTMLElement & { offsetWidth: number }).offsetWidth;
      portrait.style.animation = 'portraitReact 0.42s cubic-bezier(0.16,1,0.3,1) forwards';
      portrait.addEventListener('animationend', () => { portrait.style.animation = ''; }, { once: true });
    }

    function switchTab(next: string, filterStat: string | null = null): void {
      if (next === current || busy) return;
      busy = true;

      const outPanel = document.getElementById(`panel-${current}`)!;
      const inPanel  = document.getElementById(`panel-${next}`)!;

      const nextTab = document.querySelector<HTMLElement>(`.s-tab[data-tab="${next}"]`);
      if (nextTab) moveIndicator(nextTab);

      tabs.forEach(t => {
        const active = t.dataset.tab === next;
        t.classList.toggle('active', active);
        t.setAttribute('aria-selected', String(active));
      });

      reactPortrait();
      const exitDur = exitItems(outPanel);

      setTimeout(fireSlash, exitDur * 0.45);

      setTimeout(() => {
        outPanel.classList.remove('active');
        getItems(outPanel).forEach(el => { el.style.animation = ''; el.style.opacity = ''; });

        inPanel.style.clipPath = 'polygon(0 100%,100% 100%,100% 100%,0 100%)';
        inPanel.style.opacity  = '0.7';
        inPanel.style.animation = 'none';
        inPanel.classList.add('active');
        void (inPanel as HTMLElement & { offsetWidth: number }).offsetWidth;
        inPanel.style.animation = 'panelWipe 0.4s cubic-bezier(0.16,1,0.3,1) forwards';
        inPanel.addEventListener('animationend', () => {
          inPanel.style.animation = '';
          inPanel.style.clipPath  = '';
          inPanel.style.opacity   = '';
          busy = false;
        }, { once: true });

        if (filterStat) setLogFilter(filterStat);
        enterItems(inPanel, 60);
        current = next;
      }, exitDur);
    }

    /* ── Stat mode toggle ─────────────────────────────── */
    const dataEl     = document.getElementById('stream-tally-data')!;
    const recentData = JSON.parse(dataEl?.dataset.recent ?? '{}') as Record<string, number>;
    const allData    = JSON.parse(dataEl?.dataset.all    ?? '{}') as Record<string, number>;

    document.querySelectorAll<HTMLButtonElement>('.s-toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.s-toggle-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const mode  = btn.dataset.mode as 'recent' | 'all';
        const tally = mode === 'recent' ? recentData : allData;

        document.querySelectorAll<SVGTextElement>('[data-vertex-count]').forEach(el => {
          el.textContent = String(tally[el.dataset.vertexCount!] ?? 0);
        });

        const radarRecent = document.getElementById('radar-recent')!;
        const radarAll    = document.getElementById('radar-all')!;
        if (mode === 'recent') {
          radarRecent.classList.remove('is-secondary');
          radarAll.classList.remove('is-primary');
        } else {
          radarRecent.classList.add('is-secondary');
          radarAll.classList.add('is-primary');
        }
      });
    });

    /* ── Journal log filter ───────────────────────────── */
    function setLogFilter(stat: string): void {
      document.querySelectorAll<HTMLElement>('.j-stream-strip').forEach(s => {
        const isMatch = stat !== 'all' && s.dataset.stat === stat;
        s.classList.toggle('active', isMatch);
        if (isMatch) activeStrip = s;
      });
      if (stat === 'all') activeStrip = null;

      const label = document.getElementById('log-label');
      if (label) label.textContent = stat === 'all' ? 'Session Log' : `Session Log · ${stat}`;

      document.querySelectorAll<HTMLElement>('.j-entry').forEach(entry => {
        if (stat === 'all') { entry.hidden = false; return; }
        const stats: string[] = JSON.parse(entry.dataset.stats ?? '[]');
        entry.hidden = !stats.includes(stat);
      });
    }

    document.querySelectorAll<HTMLElement>('.j-stream-strip').forEach(strip => {
      strip.addEventListener('click', () => {
        setLogFilter(activeStrip === strip ? 'all' : strip.dataset.stat!);
      });
    });

    /* ── Radar vertex click → journal + filter ────────── */
    document.querySelectorAll<SVGGElement>('.radar-vertex').forEach(g => {
      g.addEventListener('click', () => {
        const stat = g.dataset.stat!;
        if (current === 'journal') {
          setLogFilter(activeStrip?.dataset.stat === stat ? 'all' : stat);
        } else {
          switchTab('journal', stat);
        }
      });
    });

    /* ── Tab clicks ───────────────────────────────────── */
    tabs.forEach(tab => tab.addEventListener('click', () => switchTab(tab.dataset.tab!)));

    /* ── Bond detail ──────────────────────────────────── */
    interface BondData {
      name: string; arcana: string; affinity: string; rank: number;
      stat: string | null; statColor: string | null;
      reachedDate: string | null; lore: string | null;
      lastSession: string | null; lastInteraction: string | null;
      img: string | null;
    }

    const bondsDataEl = document.getElementById('bonds-data');
    if (bondsDataEl) {
      const allBonds: BondData[] = JSON.parse(bondsDataEl.dataset.bonds ?? '[]');
      const bondMap = Object.fromEntries(allBonds.map(b => [b.name, b]));
      const detailPanel = document.getElementById('panel-bonds')!;
      let activeBondRow: HTMLElement | null = null;

      function openBondDetail(row: HTMLElement): void {
        const d = bondMap[row.dataset.bond!];
        if (!d) return;
        const color = d.statColor ?? '#888';

        const emblemEl = document.getElementById('bd-emblem')!;
        emblemEl.style.cssText = `border:1.5px solid ${color}4d;background:${color}10;box-shadow:0 0 28px ${color}1a`;
        const imgEl = document.getElementById('bd-img') as HTMLImageElement;
        if (d.img) { imgEl.src = d.img; imgEl.style.display = ''; }
        else { imgEl.style.display = 'none'; }

        document.getElementById('bd-arcana')!.textContent   = d.arcana;
        const nameEl = document.getElementById('bd-name')!;
        nameEl.textContent = d.name;
        nameEl.style.color = color;
        document.getElementById('bd-affinity')!.textContent = d.affinity;

        const badge = document.getElementById('bd-stat-badge')!;
        if (d.stat) {
          badge.style.display = 'inline-flex';
          badge.style.borderColor = `${color}4d`;
          document.getElementById('bd-stat-dot')!.style.background = color;
          document.getElementById('bd-stat-text')!.textContent = d.stat;
        } else {
          badge.style.display = 'none';
        }

        const numerals   = ['I','II','III','IV','V'];
        const rankLabelEl = document.getElementById('bd-rank-label')!;
        rankLabelEl.textContent = d.rank === 0 ? 'RANK —' : `RANK ${numerals[d.rank - 1] ?? d.rank}`;
        rankLabelEl.style.color = color;

        const pipsEl = document.getElementById('bd-rank-pips');
        pipsEl?.querySelectorAll<HTMLElement>('.bd-pip-d').forEach((pip, i) => {
          const filled = i < d.rank;
          pip.style.cssText = filled
            ? `--bd-color:${color};--bd-glow:${color}66;background:${color};border-color:${color};box-shadow:0 0 6px ${color}66`
            : '';
          pip.classList.toggle('filled', filled);
        });

        document.getElementById('bd-rank-date')!.textContent   = d.reachedDate ? `Reached · ${d.reachedDate}` : '';
        document.getElementById('bd-lore')!.textContent        = d.lore ?? '';
        document.getElementById('bd-memory')!.textContent      = d.lastSession ?? '';
        document.getElementById('bd-memory-when')!.textContent = d.lastInteraction ?? '';

        document.querySelectorAll('.bond-row').forEach(r => {
          r.classList.remove('bd-active');
          (r as HTMLElement).style.removeProperty('--bd-row-color');
        });
        row.classList.add('bd-active');
        row.style.setProperty('--bd-row-color', color);
        activeBondRow = row;
        detailPanel.classList.add('detail-open');
      }

      function closeBondDetail(): void {
        detailPanel.classList.remove('detail-open');
        document.querySelectorAll('.bond-row').forEach(r => {
          r.classList.remove('bd-active');
          (r as HTMLElement).style.removeProperty('--bd-row-color');
        });
        activeBondRow = null;
      }

      document.querySelectorAll<HTMLElement>('.bond-row').forEach(row => {
        row.addEventListener('click', () => {
          if (row === activeBondRow) closeBondDetail();
          else openBondDetail(row);
        });
      });

      document.getElementById('bond-detail-close')?.addEventListener('click', closeBondDetail);
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && activeBondRow) closeBondDetail();
      });
    }

    /* ── Page load animations ─────────────────────────── */
    const sidebar     = document.getElementById('sidebar');
    const contentArea = document.getElementById('content-area');
    if (sidebar)     sidebar.style.animation     = 'sidebarIn 0.4s cubic-bezier(0.16,1,0.3,1) forwards';
    if (contentArea) contentArea.style.animation = 'contentIn 0.45s cubic-bezier(0.16,1,0.3,1) 0.12s both';

    const activeTab = document.querySelector<HTMLElement>('.s-tab.active');
    if (activeTab) moveIndicator(activeTab);
  });
</script>
