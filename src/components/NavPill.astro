---
interface Props {
  backLink?: string;
  backLabel?: string;
}

const { backLink, backLabel } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const SECTIONS = [
  { href: '/', label: 'Home', match: ['/'] },
  { href: '/journal', label: 'Journal', match: ['/journal', '/notes', '/showcase'] },
  { href: '/novel', label: 'Novel', match: ['/novel'] },
  { href: '/shelf', label: 'Shelf', match: ['/shelf'] },
  { href: '/stream', label: 'Stream', match: ['/stream'] },
  { href: '/now', label: 'Now', match: ['/now'] },
  { href: '/codex', label: 'Codex', match: ['/codex'] },
];

const isActive = (section: (typeof SECTIONS)[number]) =>
  section.href === '/'
    ? isHome
    : section.match.some(m => currentPath === m || currentPath.startsWith(`${m}/`));
---

{!isHome && (
  <nav class="nav-bar" aria-label="Site sections">
    <div class="nav-bar__shadow">
      <div class="nav-bar__inner">
        {SECTIONS.map(section => (
          <a
            href={section.href}
            class:list={['nav-bar__item', { 'nav-bar__item--active': isActive(section) }]}
            aria-current={isActive(section) ? 'page' : undefined}
          >
            <span class="nav-bar__text">{section.label}</span>
          </a>
        ))}
        {backLink && backLabel && (
          <a href={backLink} class="nav-bar__item nav-bar__back">
            <span class="nav-bar__text">&larr; {backLabel}</span>
          </a>
        )}
      </div>
    </div>
  </nav>
)}

<style>
  .nav-bar {
    position: fixed;
    bottom: var(--space-md);
    left: var(--space-md);
    z-index: 100;
  }

  /* clip-path clips box-shadow — hard gold shadow lives on a drop-shadow wrapper */
  .nav-bar__shadow {
    filter: drop-shadow(4px 4px 0 rgba(255, 229, 44, 0.3));
  }

  .nav-bar__inner {
    display: flex;
    align-items: stretch;
    background: var(--color-black);
    border: var(--border-medium) solid var(--color-gold);
    clip-path: polygon(
      var(--cut-md) 0,
      100% 0,
      100% calc(100% - var(--cut-md)),
      calc(100% - var(--cut-md)) 100%,
      0 100%,
      0 var(--cut-md)
    );
  }

  .nav-bar__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-xs) var(--space-md);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    text-decoration: none;
    overflow: hidden;
    transition: color var(--transition-fast);
  }

  .nav-bar__item + .nav-bar__item {
    border-left: 1px solid rgba(255, 229, 44, 0.18);
  }

  .nav-bar__text {
    position: relative;
    z-index: 1;
    display: inline-block;
    transform: skewX(var(--skew-display));
    white-space: nowrap;
  }

  /* P4G diagonal gold sweep on hover/focus */
  .nav-bar__item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-gold);
    transform: translateX(-110%) skewX(var(--skew-accent));
    transition: transform var(--animation-fast) var(--animation-easing);
  }

  .nav-bar__item:hover,
  .nav-bar__item:focus-visible {
    color: var(--color-black);
  }

  .nav-bar__item:hover::before,
  .nav-bar__item:focus-visible::before {
    transform: translateX(0) skewX(0deg);
  }

  .nav-bar__item:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: -2px;
  }

  /* Current section — solid gold command */
  .nav-bar__item--active {
    background: var(--color-gold);
    color: var(--color-black);
  }

  .nav-bar__item--active::before {
    display: none;
  }

  .nav-bar__back {
    color: var(--color-gold);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-bar__item::before {
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .nav-bar {
      left: var(--space-sm);
      right: var(--space-sm);
      bottom: var(--space-sm);
    }

    /* Two-row wrap: gap + gold-tinted inner background paints hairlines
       between rows and columns without per-item border bookkeeping */
    .nav-bar__inner {
      flex-wrap: wrap;
      gap: 1px;
      background: rgba(255, 229, 44, 0.18);
    }

    .nav-bar__item {
      flex: 1 1 24%;
      min-height: 44px;
      padding: var(--space-xs) var(--space-2xs);
      font-size: 0.7rem; /* was 0.6rem (~9.6px) — too small for the primary nav */
      background: var(--color-black);
    }

    .nav-bar__item + .nav-bar__item {
      border-left: none;
    }

    .nav-bar__item--active {
      background: var(--color-gold);
    }
  }
</style>

<script>
  // Publishes the nav's real height so pages can pad their bottom edge —
  // the two-row mobile bar must never cover content.
  function setNavClearance() {
    const nav = document.querySelector<HTMLElement>('.nav-bar');
    const clearance = nav ? nav.offsetHeight + 16 : 0;
    document.documentElement.style.setProperty('--nav-clearance', `${clearance}px`);
  }
  setNavClearance();
  document.addEventListener('astro:page-load', setNavClearance);
  window.addEventListener('resize', setNavClearance);
</script>
